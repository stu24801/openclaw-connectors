# LLM Proxy 環境變數範本
# 複製為 .env 並填入實際值，不要 commit .env

# banana-slides 等 client 用這個 token 呼叫 proxy（自訂一個強密碼）
PROXY_TOKEN=change-me-to-a-strong-random-token

# 預設使用的 GitHub Copilot 模型（無需 API Key，使用 OpenClaw 已配置的 Copilot 憑證）
DEFAULT_MODEL=gemini-3.1-pro-preview

# OpenClaw 安裝路徑（根據實際安裝位置調整）
OPENCLAW_BIN=/home/<your-user>/.npm-global/bin/openclaw

# GitHub Copilot token 路徑（OpenClaw 自動管理）
GH_COPILOT_CRED=/home/<your-user>/.openclaw/credentials/github-copilot.token.json

# GitHub Copilot API
COPILOT_API_BASE=https://api.githubcopilot.com

# 請求 timeout（秒）
CALL_TIMEOUT=300

# 日誌目錄
LOG_DIR=/opt/llm-proxy/logs

# 可選：開啟 RAG 知識庫自動注入
# 設定後，每個請求會先搜尋知識庫並將相關內容注入 system prompt
# RAG_ENDPOINT=http://127.0.0.1:8765/search
