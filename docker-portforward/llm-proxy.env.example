# Port-forward config for llm-proxy → Docker containers
# Copy to: ~/.config/portforward/llm-proxy.env

# IP to bind — must be reachable from Docker containers.
# Use the docker bridge gateway (find with: docker network inspect <net> | grep Gateway)
LISTEN_HOST=172.18.0.1

# Port Docker containers will connect to
LISTEN_PORT=9090

# Where to forward to (the real service listening on loopback)
DST_HOST=127.0.0.1
DST_PORT=9000
